# Main FastAPI backend -> DeepEdit inference service
# Prefer :8010; if occupied, start DeepEdit on :8011 and set this URL accordingly.
DEEPEDIT_SERVICE_URL=http://127.0.0.1:8010
DEEPEDIT_SERVICE_TIMEOUT_SECONDS=120

# Quality report AI polish (OpenAI-compatible Chat Completions)
# Leave REPORT_POLISH_API_KEY empty to disable; generate-report still works offline.
# REPORT_POLISH_API_KEY=
# REPORT_POLISH_BASE_URL=https://api.openai.com/v1
# Gemini: https://generativelanguage.googleapis.com/v1beta/openai
# DeepSeek: https://api.deepseek.com/v1
# 通义: https://dashscope.aliyuncs.com/compatible-mode/v1
# REPORT_POLISH_MODEL=gpt-4o-mini
# REPORT_POLISH_MODEL=gemini-2.5-pro
# REPORT_POLISH_TIMEOUT_SECONDS=90

# DeepEdit inference service (MONAI UNet checkpoint)
# Put real weights outside Git tracking:
# models/deepedit/deepedit_unet.pth
DEEPEDIT_CONFIG_PATH=models/deepedit/config.json
DEEPEDIT_MODEL_PATH=models/deepedit/deepedit_unet.pth
DEEPEDIT_MODEL_FORMAT=monai_unet_checkpoint
# Alternative TorchScript:
# DEEPEDIT_MODEL_PATH=models/deepedit/model.ts
# DEEPEDIT_MODEL_FORMAT=torchscript
DEEPEDIT_DEVICE=auto
DEEPEDIT_THRESHOLD=0.5

# TotalSegmentator workspace + inference (AI predict models totalseg_*)
# Prefer Person A standard DeepEdit port :8010 above.
# TOTALSEG_ROOT=          # e.g. D:\hm_2_totalseg or E:\lxy\hm_2_totalseg
# TOTALSEG_PYTHON=        # python that can import totalsegmentator
# TOTALSEG_DEVICE=auto    # auto=prefer GPU when available; force gpu/cpu
# TOTALSEG_FAST=          # empty=auto (fast on CPU); set true/false to force
# TOTALSEG_TIMEOUT_SECONDS=1800
# pip install TotalSegmentator   # inside TOTALSEG_PYTHON env; first run downloads weights
# 若要用 GPU：TOTALSEG_PYTHON 指向带 CUDA 的 Python，并安装 GPU 版 torch + TotalSegmentator

# Optional local environment for spleen AI prediction (Person B)
# Copy values into your shell / .env before starting the backend.
# SPLEEN_NNUNET_ROOT=E:\lxy\hm_2_spleen
