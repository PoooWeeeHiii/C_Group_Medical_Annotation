# Main FastAPI backend -> DeepEdit inference service
# Prefer :8010; if occupied, start DeepEdit on :8011 and set this URL accordingly.
DEEPEDIT_SERVICE_URL=http://127.0.0.1:8010
DEEPEDIT_SERVICE_TIMEOUT_SECONDS=120

# DeepEdit inference service (MONAI UNet checkpoint)
# Put real weights outside Git tracking:
# models/deepedit/deepedit_unet.pth
DEEPEDIT_CONFIG_PATH=models/deepedit/config.json
DEEPEDIT_MODEL_PATH=models/deepedit/deepedit_unet.pth
DEEPEDIT_MODEL_FORMAT=monai_unet_checkpoint
# Alternative TorchScript:
# DEEPEDIT_MODEL_PATH=models/deepedit/model.ts
# DEEPEDIT_MODEL_FORMAT=torchscript
DEEPEDIT_DEVICE=auto
DEEPEDIT_THRESHOLD=0.5

# TotalSegmentator workspace + inference (AI predict models totalseg_*)
# TOTALSEG_ROOT=D:\hm_2_totalseg
# TOTALSEG_PYTHON=D:\hm_2_spleen\venv_nnunet_cpu\Scripts\python.exe
# TOTALSEG_DEVICE=auto          # auto=优先 GPU（检测 TOTALSEG_PYTHON 环境），无 GPU 则 CPU；可强制 gpu/cpu
# TOTALSEG_FAST=                # 空=自动（CPU 开 fast，GPU 默认全精度）；true/false 可强制
# TOTALSEG_TIMEOUT_SECONDS=1800
# pip install TotalSegmentator   # inside TOTALSEG_PYTHON env; first run downloads weights
# 若要用 GPU：TOTALSEG_PYTHON 指向带 CUDA 的 Python，并安装 GPU 版 torch + TotalSegmentator

# Optional local environment for spleen AI prediction (Person B)
# Copy values into your shell before starting the backend.
# SPLEEN_NNUNET_ROOT=D:\hm_2_spleen
# SPLEEN_MODEL_DIR=D:\hm_2_spleen\nnUNet_results\Dataset506_Spleen\nnUNetTrainer_100epochs__nnUNetPlans__2d
# SPLEEN_CHECKPOINT_NAME=checkpoint_best.pth
# Prefer the CPU env if the GPU env hangs on import; switch to venv_nnunet when CUDA works.
# SPLEEN_NNUNET_PYTHON=D:\hm_2_spleen\venv_nnunet_cpu\Scripts\python.exe
# nnUNet_raw=D:\hm_2_spleen\nnUNet_raw
# nnUNet_preprocessed=D:\hm_2_spleen\nnUNet_preprocessed
# nnUNet_results=D:\hm_2_spleen\nnUNet_results
# Or use a shell command template:
# SPLEEN_NNUNET_PREDICT_COMMAND=nnUNetv2_predict -i {input_dir} -o {output_dir} -d 506 -c 2d -f 0

# When training TotalSeg-derived datasets, point nnUNet_* to:
